"platform\stm32f1xx_hal.o"
"platform\stm32f1xx_hal_rcc.o"
"platform\stm32f1xx_hal_rcc_ex.o"
"platform\stm32f1xx_hal_gpio.o"
"platform\stm32f1xx_hal_dma.o"
"platform\stm32f1xx_hal_cortex.o"
